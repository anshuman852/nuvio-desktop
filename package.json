{
  "name": "nuvio-desktop",
  "version": "2.4.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "bump": "node scripts/bump-version.js",
    "tauri:build": "tauri build && node -e \"const fs=require('fs'),p=require('path');const out=p.join('out');fs.mkdirSync(out,{recursive:true});['nsis','msi'].forEach(b=>{const d=p.join('src-tauri','target','release','bundle',b);if(fs.existsSync(d)){fs.readdirSync(d).forEach(f=>{if(f.endsWith('.exe')||f.endsWith('.msi')){fs.copyFileSync(p.join(d,f),p.join(out,f));console.log('Copied',f,'to out/')}})}})\""
  },
  "dependencies": {
    "@rollup/rollup-win32-x64-msvc": "^4.60.2",
    "@tauri-apps/api": "~2.10.0",
    "@tauri-apps/cli-win32-x64-msvc": "^2.11.0",
    "@tauri-apps/plugin-shell": "^2.0.0",
    "@tauri-apps/plugin-store": "^2.4.2",
    "axios": "^1.7.7",
    "clsx": "^2.1.1",
    "express": "^5.2.1",
    "hls.js": "^1.6.16",
    "http-proxy-middleware": "^3.0.5",
    "lucide-react": "^0.400.0",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.27.0",
    "tauri-plugin-libmpv-api": "^0.3.2",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.1.0",
    "@types/qrcode.react": "^1.0.5",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  },
  "description": "[![Release](https://img.shields.io/github/v/release/Davako94/nuvio-desktop?style=for-the-badge&color=7c3aed)](https://github.com/Davako94/nuvio-desktop/releases/latest) [![License](https://img.shields.io/github/license/Davako94/nuvio-desktop?style=for-the-badge)](LICENSE) [![CI](https://img.shields.io/github/actions/workflow/status/Davako94/nuvio-desktop/ci.yml?style=for-the-badge&label=build)](https://github.com/Davako94/nuvio-desktop/actions) [![Windows](https://img.shields.io/badge/platform-Windows-0078d7?style=for-the-badge&logo=windows)](https://github.com/Davako94/nuvio-desktop/releases/latest)",
  "main": "postcss.config.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Davako94/nuvio-desktop.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
