{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for Nuvio Desktop",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "store:default",
    "core:window:allow-start-dragging",
    "core:window:allow-set-fullscreen",
    "core:webview:allow-set-webview-zoom"
  ]
}
