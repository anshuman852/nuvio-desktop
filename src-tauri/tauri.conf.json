{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "nuvio-desktop",
  "version": "2.1.9",
  "identifier": "com.nuvio.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Nuvio Desktop",
        "width": 1280,
        "height": 720,
        "minWidth": 800,
        "minHeight": 600,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "visible": true,
        "focus": true,
        "devtools": true,
        "additionalBrowserArgs": "--autoplay-policy=no-user-gesture-required --allow-running-insecure-content"
      }
    ],
    "security": {
      "csp": null,
      "dangerousDisableAssetCspModification": true,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["resources/*"],
    "copyright": "",
    "category": "Video",
    "shortDescription": "Nuvio Desktop App",
    "longDescription": "A streaming app for movies and TV series",
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "nsis": {
        "installerIcon": "icons/icon.ico"
      }
    }
  }
}